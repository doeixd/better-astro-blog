---
import { getImage, Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	// Collect all unique tags
	const tags = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			tags.add(tag);
		}
	}

	return [...tags].map((tag) => {
		const filtered = posts
			.filter((post) => post.data.tags?.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { tag },
			props: { posts: filtered, tag },
		};
	});
}

const { posts, tag } = Astro.props;
const pageTitle = `Posts tagged "${tag}" — ${SITE_TITLE}`;
const pageDescription = `All blog posts tagged with "${tag}".`;
const postsWithPlaceholders = await Promise.all(
	posts.map(async (post) => ({
		...post,
		heroPlaceholder: post.data.heroImage
			? await getImage({
					src: post.data.heroImage,
					width: 32,
					format: 'webp',
					quality: 30,
				})
			: null,
		imageTransitionName: `post-image-${post.id.replace(/[^a-zA-Z0-9_-]+/g, '-')}`,
	})),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 960px;
			}
			.tag-header {
				margin-bottom: 2rem;
			}
			.tag-header h1 {
				font-size: 2em;
			}
			.tag-header a {
				font-size: 0.9em;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
				content-visibility: auto;
				contain-intrinsic-size: 0 300px;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				display: block;
				width: 100%;
				height: auto;
				margin-bottom: 0.5rem;
				position: relative;
				z-index: 1;
			}
			ul li a {
				display: block;
			}
			.card-media {
				aspect-ratio: var(--card-aspect-ratio, 2 / 1);
				background:
					linear-gradient(135deg, rgba(var(--gray-light), 0.9), rgba(var(--gray), 0.18)),
					var(--card-placeholder-url, none) center/cover no-repeat;
				border-radius: 12px;
				overflow: hidden;
				position: relative;
				margin-bottom: 0.5rem;
			}
			.card-media::before {
				content: '';
				position: absolute;
				inset: 0;
				background: var(--card-placeholder-url, none) center/cover no-repeat;
				filter: blur(22px);
				transform: scale(1.08);
				opacity: 0.82;
				z-index: 0;
			}
			.card-media :global(picture) {
				display: block;
				position: relative;
				z-index: 1;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover .card-media,
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="tag-header">
				<h1>Tag: {tag}</h1>
				<a href="/blog/">&larr; All posts</a>
			</div>
			<section>
				<ul>
					{
						postsWithPlaceholders.map((post, index) => (
							<li>
							<a href={`/blog/${post.id}/`} data-mousedown-nav>
									{post.data.heroImage && (
										<div
											class="card-media"
											style={`--card-placeholder-url: ${post.heroPlaceholder ? `url(${post.heroPlaceholder.src})` : 'none'}; --card-aspect-ratio: ${post.data.heroImage.width} / ${post.data.heroImage.height}; view-transition-name: ${post.imageTransitionName};`}
										>
											<Picture
												src={post.data.heroImage}
												formats={['avif', 'webp']}
												widths={[360, 720]}
												sizes="(max-width: 720px) 100vw, 720px"
												width={720}
												height={360}
												alt={post.data.heroImageAlt || ''}
												loading={index === 0 ? 'eager' : 'lazy'}
												{...(index === 0 ? { fetchpriority: 'high' } : {})}
											/>
										</div>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
