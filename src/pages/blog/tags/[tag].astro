---
import { getImage, Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

const basePath = import.meta.env.BASE_URL;

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	const tags = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			tags.add(tag);
		}
	}

	return [...tags].map((tag) => {
		const filtered = posts
			.filter((post) => post.data.tags?.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { tag },
			props: { posts: filtered, tag },
		};
	});
}

const { posts, tag } = Astro.props;
const pageTitle = `Posts tagged "${tag}" — ${SITE_TITLE}`;
const pageDescription = `All blog posts tagged with "${tag}".`;
const postsWithPlaceholders = await Promise.all(
	posts.map(async (post) => ({
		...post,
		heroPlaceholder: post.data.heroImage
			? await getImage({
					src: post.data.heroImage,
					width: 32,
					format: 'webp',
					quality: 30,
				})
			: null,
		heroPreload: post.data.heroImage
			? await getImage({
					src: post.data.heroImage,
					width: Math.min(post.data.heroImage.width, 720),
					format: 'webp',
					quality: 75,
				})
			: null,
		imageTransitionName: `post-image-${post.id.replace(/[^a-zA-Z0-9_-]+/g, '-')}`,
	})),
);
const aboveTheFoldPreloads = postsWithPlaceholders
	.slice(0, 4)
	.map((post) => post.heroPreload)
	.filter((image) => image !== null);

/* ── Inline style constants (literal values to prevent FOUC) ── */
const TEXT_PADDING = '1.5px';
const TITLE_SIZE = '1.563em';

const cardTextStyle = `display:block;padding:${TEXT_PADDING} ${TEXT_PADDING} 0;`;
const titleRowStyle = 'display:flex;justify-content:space-between;align-items:baseline;gap:0.5em;';
const titleStyle = `margin:0;line-height:1;font-size:${TITLE_SIZE};`;
const dateStyle = 'margin:0;white-space:nowrap;font-size:0.8em;';
const subtitleStyle = 'margin:0.25em 0 0;font-style:italic;font-size:0.9em;';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		{aboveTheFoldPreloads.map((image) => (
			<link rel="preload" as="image" href={image.src} type="image/webp" fetchpriority="high" />
		))}
		<style>
			/* ── Tokens ── */
			:root {
				--card-grid-width: 960px;
				--card-grid-gap: 2rem;
				--card-radius: 12px;
				--card-blur: 22px;
				--card-title-max: 26ch;
			}

			/* ── Page ── */
			main {
				width: var(--card-grid-width);
			}

			/* ── Tag header ── */
			.tag-header {
				margin-bottom: 2rem;
			}
			.tag-header h1 {
				font-size: 2em;
			}
			.tag-header a {
				font-size: 0.9em;
			}

			/* ── Grid ── */
			.card-grid {
				display: flex;
				flex-wrap: wrap;
				gap: var(--card-grid-gap);
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.card-grid > li {
				width: calc(50% - var(--card-grid-gap) / 2);
				min-width: 0;
			}

			/* ── Link reset ── */
			.card-grid a {
				display: block;
				text-decoration: none;
				color: inherit;
			}

			/* ── Hover ── */
			.card-grid a:hover .title,
			.card-grid a:hover .date {
				color: rgb(var(--accent));
			}
			.card-grid a:hover .card-media {
				box-shadow: var(--box-shadow);
			}

			/* ── Card image ── */
			.card-media {
				aspect-ratio: var(--card-aspect-ratio, 2 / 1);
				background:
					linear-gradient(135deg, rgba(var(--gray-light), 0.9), rgba(var(--gray), 0.18)),
					var(--card-placeholder-url, none) center / cover no-repeat;
				border-radius: var(--card-radius);
				overflow: hidden;
				position: relative;
				margin-bottom: 0.5rem;
				transition: box-shadow 0.2s ease-out;
			}
			.card-media::before {
				content: '';
				position: absolute;
				inset: 0;
				background: var(--card-placeholder-url, none) center / cover no-repeat;
				filter: blur(var(--card-blur));
				transform: scale(1.08);
				opacity: 0.82;
				z-index: 0;
			}
			.card-media :global(picture) {
				display: block;
				position: relative;
				z-index: 1;
			}
			.card-media img {
				display: block;
				width: 100%;
				height: auto;
			}

			/* ── Card text (colors & overflow only — layout is inlined) ── */
			.title {
				color: rgb(var(--black));
				max-width: var(--card-title-max);
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.subtitle {
				padding-left: 1px;
				color: rgb(var(--gray));
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.date {
				color: rgb(var(--gray));
				flex-shrink: 0;
			}

			/* ── Mobile ── */
			@media (max-width: 720px) {
				:root {
					--card-grid-gap: 0.5em;
				}
				.card-grid > li {
					width: 100%;
				}
				.subtitle {
					white-space: normal;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="tag-header">
				<h1>Tag: {tag}</h1>
				<a href={`${basePath}blog/`}>&larr; All posts</a>
			</div>
			<section>
				<ul class="card-grid">
					{
						postsWithPlaceholders.map((post, index) => (
							<li>
								<a href={`${basePath}blog/${post.id}/`} data-mousedown-nav data-hero-preload={post.heroPreload?.src}>
									{post.data.heroImage && (
										<div
											class="card-media"
											style={`--card-placeholder-url:${post.heroPlaceholder ? `url(${post.heroPlaceholder.src})` : 'none'};--card-aspect-ratio:${post.data.heroImage.width} / ${post.data.heroImage.height};view-transition-name:${post.imageTransitionName};`}
										>
										<Picture
											src={post.data.heroImage}
											formats={['webp', 'avif']}
											widths={[360, 720]}
											sizes="(max-width: 720px) 100vw, 720px"
											width={720}
											height={360}
											alt={post.data.heroImageAlt || ''}
											loading={index < 4 ? 'eager' : 'lazy'}
											{...(index < 4 ? { fetchpriority: 'high' } : {})}
										/>
										</div>
									)}
									<div class="card-text" style={cardTextStyle}>
										<div class="card-title-row" style={titleRowStyle}>
											<h4 class="title" style={titleStyle}>{post.data.title}</h4>
											<p class="date" style={dateStyle}>
												<FormattedDate date={post.data.pubDate} short />
											</p>
										</div>
										{post.data.subtitle && <p class="subtitle" style={subtitleStyle}>{post.data.subtitle}</p>}
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const preloaded = new Set<string>();
			document.addEventListener('pointerenter', (e) => {
				const anchor = (e.target as Element).closest?.('a[data-hero-preload]');
				if (!(anchor instanceof HTMLAnchorElement)) return;
				const src = anchor.dataset.heroPreload;
				if (!src || preloaded.has(src)) return;
				preloaded.add(src);
				const link = document.createElement('link');
				link.rel = 'preload';
				link.as = 'image';
				link.href = src;
				link.type = 'image/webp';
				document.head.appendChild(link);
			}, true);
		</script>
	</body>
</html>
