---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const normalizePath = (value: string) => {
	const withoutBase = value.startsWith(basePath) ? value.slice(basePath.length - 1) : value;
	const normalized = withoutBase.startsWith('/') ? withoutBase : `/${withoutBase}`;
	return normalized !== '/' ? normalized.replace(/\/+$/, '') : normalized;
};
const pathname = normalizePath(Astro.url.pathname);
const linkPath = normalizePath(String(href));
const subpath = pathname.match(/[^\/]+/g);
const isActive = linkPath === pathname || linkPath === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} data-mousedown-nav {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
